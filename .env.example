# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/budget
POSTGRES_PORT=5432

# ── Ports ────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=8080

# ── Application ──────────────────────────────────────────
DEBUG=true
AUTH_DISABLED=true
SECRET_KEY=change-me-in-production

# ── Admin ────────────────────────────────────────────────
ADMIN_EMAIL=admin@localhost
ADMIN_NAME=Administrator

# ── Azure Entra ID (set in production) ───────────────────
VITE_AZURE_CLIENT_ID=placeholder-client-id
VITE_AZURE_TENANT_ID=placeholder-tenant-id
AZURE_CLIENT_SECRET=
VITE_AUTH_DISABLED=true

# ── Email ────────────────────────────────────────────────
MAIL_SENDER_EMAIL=

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8080"]

# ── URL Prefix (for reverse proxy path-based routing) ────
URL_PREFIX=
VITE_URL_PREFIX=
VITE_API_BASE_URL=/api/v1

# ── Backup ───────────────────────────────────────────────
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=30
